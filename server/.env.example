CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
SERVER_URL=http://localhost:5000
PORT=5000
NODE_ENV=development
TRUST_PROXY=false

# Comma-separated server-side admin allowlist. Leave empty in local dev only.
ADMIN_ALLOWED_EMAILS=owner@example.com

# Basic API throttling
RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
WRITE_RATE_LIMIT_MAX=30

CASHFREE_ENV=sandbox
CASHFREE_BASE_URL=https://sandbox.cashfree.com/pg
CASHFREE_API_VERSION=2025-01-01
CASHFREE_APP_ID=TEST_your_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here

# Firebase Admin: use either BASE64 full JSON, or project/client/private key.
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=santosh-salon
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@santosh-salon.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=

CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_cloud_api_key
CLOUD_API_SECRET=your_cloud_api_secret
CLOUDINARY_FOLDER=salon-services
