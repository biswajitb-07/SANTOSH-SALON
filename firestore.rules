rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isContactOwner() {
      return signedIn() &&
        (resource.data.userId == request.auth.uid ||
          resource.data.email == request.auth.token.email);
    }

    function isNewContactOwner() {
      return signedIn() &&
        (request.resource.data.userId == request.auth.uid ||
          request.resource.data.email == request.auth.token.email);
    }

    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow create, read, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /salons/{salonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /barberStats/{barberId} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if isAdmin();
    }

    match /bookingCounters/{counterId} {
      allow read: if signedIn() || isAdmin();
      allow create, update: if signedIn() || isAdmin();
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /refundRequests/{refundId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow update, delete: if isAdmin();
    }

    match /contactIssues/{issueId} {
      allow create: if signedIn() && isNewContactOwner();
      allow read: if isAdmin() || isContactOwner();
      allow update: if isAdmin() ||
        (isContactOwner() &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.userId == resource.data.userId);
      allow delete: if isAdmin() || isContactOwner();
    }

    match /paymentEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /webhookEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
